---
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname.startsWith('/blog');
const isAbout = pathname === '/about' || pathname.startsWith('/about');
const isTags = pathname.startsWith('/tags');
---

<nav class="ed-nav" aria-label="Primary">
  <a href="/" class="ed-nav-left">
    shirone<span class="dot">.</span><b>blog</b>
  </a>
  <div class="ed-nav-center">Est. MMXXVI · Poland</div>
  <div class="ed-nav-right">
    <a href="/" class:list={[isHome && 'on']}>Writing</a>
    <a href="/about" class:list={[isAbout && 'on']}>About</a>
    <a href="/tags" class:list={[isTags && 'on']}>Tags</a>
    <a href="/rss.xml">RSS</a>
  </div>
</nav>
