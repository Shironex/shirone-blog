---
import FormattedDate from './FormattedDate.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  featured?: boolean;
}

const { title, description, pubDate, tags, slug, featured = false } = Astro.props;
---

<a href={`/blog/${slug}/`} class="group block">
  <article class:list={[
    'rounded-lg border border-[var(--color-border)] p-6 transition-all duration-300',
    'hover:border-[var(--color-amber-dim)] hover:bg-[var(--color-surface)]',
    featured && 'border-l-2 border-l-[var(--color-amber-dim)]',
  ]}>
    <div class="mb-2 text-sm text-[var(--color-text-faint)]">
      <FormattedDate date={pubDate} />
    </div>
    <h3 class:list={[
      'mb-2 font-semibold leading-snug tracking-tight transition-colors group-hover:text-[var(--color-amber)]',
      featured ? 'text-xl' : 'text-lg',
    ]} style="font-family: var(--font-display);">
      {title}
    </h3>
    <p class="mb-3 text-sm leading-relaxed text-[var(--color-text-muted)]">
      {description}
    </p>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="text-xs text-[var(--color-sage)]">#{tag}</span>
        ))}
      </div>
    )}
  </article>
</a>
