---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  readingTime: string;
  id: number;
}

const { title, description, pubDate, tags, slug, readingTime, id } = Astro.props;
const month = pubDate.toLocaleDateString('en-us', { month: 'short' });
const day = pubDate.toLocaleDateString('en-us', { day: 'numeric' });
const year = pubDate.getFullYear();
const idPadded = String(id).padStart(2, '0');
const readMinutes = readingTime.replace(' min read', 'm');
---

<a href={`/blog/${slug}/`} class="ed-row">
  <div class="ed-row-date">
    <span class="yr">{year}</span>
    {`${month} ${day}`}
  </div>
  <div>
    <h3 class="ed-row-title">{title}</h3>
    <p class="ed-row-dek">{description}</p>
    {tags.length > 0 && (
      <div class="ed-row-tags">
        {tags.map((tag) => <span>#{tag}</span>)}
      </div>
    )}
  </div>
  <div class="ed-row-meta">
    № {idPadded}
    <span class="read">{readMinutes}</span>
  </div>
</a>
