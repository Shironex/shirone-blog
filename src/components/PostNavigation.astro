---
interface NavPost {
  slug: string;
  title: string;
}

interface Props {
  prev?: NavPost;
  next?: NavPost;
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="ed-article-foot" aria-label="Post navigation">
    {prev ? (
      <a href={`/blog/${prev.slug}/`}>
        <div class="dir">← Previous</div>
        <div class="nxt">{prev.title}</div>
      </a>
    ) : <div />}
    {next ? (
      <a href={`/blog/${next.slug}/`} class="right">
        <div class="dir">Next →</div>
        <div class="nxt">{next.title}</div>
      </a>
    ) : <div />}
  </nav>
)}
