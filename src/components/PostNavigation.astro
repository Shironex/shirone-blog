---
interface NavPost {
  slug: string;
  title: string;
}

interface Props {
  prev?: NavPost;
  next?: NavPost;
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="mt-16 flex items-stretch gap-4 border-t border-border pt-8" aria-label="Post navigation">
    {prev ? (
      <a href={`/blog/${prev.slug}/`} class="group flex flex-1 flex-col gap-1 text-left">
        <span class="text-xs text-text-faint">&larr; Previous</span>
        <span class="text-sm font-medium text-text-muted transition-colors group-hover:text-amber" style="font-family: var(--font-display);">
          {prev.title}
        </span>
      </a>
    ) : <div class="flex-1" />}
    {next ? (
      <a href={`/blog/${next.slug}/`} class="group flex flex-1 flex-col gap-1 text-right">
        <span class="text-xs text-text-faint">Next &rarr;</span>
        <span class="text-sm font-medium text-text-muted transition-colors group-hover:text-amber" style="font-family: var(--font-display);">
          {next.title}
        </span>
      </a>
    ) : <div class="flex-1" />}
  </nav>
)}
