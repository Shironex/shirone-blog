---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <nav class="ed-toc" aria-label="Table of contents">
    <span class="label">On this page</span>
    <ol>
      {filtered.map((heading) => (
        <li class:list={[heading.depth === 3 && 'nested']}>
          <a href={`#${heading.slug}`}>{heading.text}</a>
        </li>
      ))}
    </ol>
  </nav>
)}
