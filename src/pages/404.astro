---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="404 — shirone.blog" description="Page not found" />
  </head>
  <body class="min-h-screen bg-[var(--color-bg)]">
    <Header />
    <main class="mx-auto flex max-w-2xl flex-col items-start px-6 py-32">
      <p class="mb-2 text-sm text-[var(--color-text-faint)]">404</p>
      <h1
        class="mb-4 text-3xl font-bold tracking-tight"
        style="font-family: var(--font-display);"
      >
        Wrong turn
      </h1>
      <p class="mb-8 text-[var(--color-text-muted)]">
        This page doesn't exist. Maybe it did once, maybe it never will.
      </p>
      <a
        href="/"
        class="text-sm text-[var(--color-amber)] transition-opacity hover:opacity-80"
      >
        &larr; Back home
      </a>
    </main>
    <Footer />
  </body>
</html>
