---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="404 — shirone.blog" description="Page not found" />
  </head>
  <body>
    <Header />
    <main class="ed-404">
      <div class="ed-404-inner">
        <div class="stamp">Error · IV · not found</div>
        <p class="big">404</p>
        <h2>This page has <em>gone missing</em>.</h2>
        <p>
          Perhaps the URL is mistyped, perhaps it was moved, perhaps it never
          existed. The archive, however, remains.
        </p>
        <div class="links">
          <a href="/">← Back to writing</a>
          <a href="/tags">Browse tags</a>
          <a href="/rss.xml">RSS feed</a>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
