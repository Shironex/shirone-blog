---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { GITHUB_URL } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="About — shirone.blog"
      description="Hey, I'm Kacper (Shirone online) — full-stack developer from Poland, building long-term projects around self-hosting, dev tooling, and AI-assisted workflows."
    />
  </head>
  <body>
    <Header />

    <main>
      <div class="ed-about">
        <div class="ed-about-grid">
          <div class="ed-portrait" aria-hidden="true">S</div>
          <div>
            <h1>Hey, I'm <em>Kacper</em>.</h1>
            <div class="role">Shirone online · Poland · Full-stack · TypeScript</div>
            <p>
              I build products and developer tools — from UI and backend to
              deployment and infra. Currently working on long-term projects
              around self-hosting, dev tooling, and AI-assisted workflows.
            </p>
            <p>
              This blog is where I write about the decisions, mistakes, and
              lessons learned from building these things. No tutorials. Just
              honest field notes from someone in the middle of the work.
            </p>
          </div>
        </div>

        <div class="ed-about-contact">
          <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub ↗</a>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .ed-about {
    max-width: 880px;
    margin: 0 auto;
    padding: 80px 48px 80px;
  }
  .ed-about-grid {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 56px;
    align-items: start;
  }
  .ed-portrait {
    width: 200px;
    height: 240px;
    background: linear-gradient(160deg, #2a2420, #1a1613);
    border: 1px solid var(--color-line);
    border-radius: 2px;
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    font-size: 96px;
    color: var(--color-accent);
    font-style: italic;
    position: relative;
    overflow: hidden;
  }
  .ed-portrait::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      transparent 0 8px,
      color-mix(in oklch, var(--color-accent) 2%, transparent) 8px 9px
    );
  }
  .ed-about h1 {
    font-family: var(--font-serif);
    font-size: clamp(40px, 6vw, 56px);
    line-height: 1;
    font-weight: 400;
    letter-spacing: -0.025em;
    margin: 0 0 8px;
  }
  .ed-about h1 em { font-style: italic; color: var(--color-accent); }
  .ed-about .role {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-mute);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 32px;
  }
  .ed-about p {
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.6;
    color: #d9d2c8;
    margin: 0 0 16px;
    max-width: 58ch;
    font-weight: 350;
    text-wrap: pretty;
  }
  .ed-about-contact {
    margin-top: 48px;
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-ink-mute);
    letter-spacing: 0.05em;
  }
  .ed-about-contact a {
    color: var(--color-ink-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .ed-about-contact a:hover { color: var(--color-accent); }

  @media (max-width: 700px) {
    .ed-about { padding: 56px 20px 64px; }
    .ed-about-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .ed-portrait {
      width: 120px;
      height: 140px;
      font-size: 56px;
    }
  }
</style>
